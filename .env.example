# Server Configuration
# Port number for the server to listen on
# Default: 5000
PORT=5000

# Admin Panel Credentials
# These credentials are used to access the admin panel at /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Authentication Mode for API Access
# Options:
#   - user_tokens: Use individual user tokens with rate limits (default)
#   - general_password: Use a single password for all users
#   - no_auth: No authentication required
AUTH_MODE=user_tokens

# General Password (only used when AUTH_MODE=general_password)
# This password will be used as Bearer token for API requests
GENERAL_PASSWORD=your-secure-password-here

# Database
# The application uses a local JSON file (database.json) for data storage
# No additional database configuration is needed

# Database Encryption Key (32 characters recommended)
# This key is used to encrypt the database.json file
# IMPORTANT: Keep this secret and back it up safely
DB_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Salt for deriving the encryption key (any random string)
# Used to protect the DB_ENCRYPTION_KEY from pre-computation attacks
SCRYPT_SALT=a-long-and-random-string-for-security

# Session Secret
# This secret is used to hash your session data and is crucial for
# safety concerns. Must be at least 32 characters long.
# Uncomment this line and set it for production.
# SESSION_SECRET=a-very-secure-string-woo-hoo

# Discord OAuth Configuration
# These credentials are obtained from Discord Developer Portal
# https://discord.com/developers/applications
CLIENT_ID=your-discord-client-id
CLIENT_SECRET=your-discord-client-secret
REDIRECT_URI=http://localhost:5000/api/auth/discord/callback